# ============================================================
# openrnd CLI - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Local LLM (Ollama) - Default provider ----------------
# Ollama: install from https://ollama.ai, then run: ollama pull llama3.2
OPENRND_BASE_URL=http://localhost:11434/v1
OPENRND_API_KEY=ollama
OPENRND_MODEL=llama3.2

# ---- LM Studio ─────────────────────────────────────────────
# OPENRND_BASE_URL=http://localhost:1234/v1
# OPENRND_API_KEY=lm-studio
# OPENRND_MODEL=local-model

# ---- OpenAI compatible (vLLM, llama.cpp server, etc.) -----
# OPENRND_BASE_URL=http://localhost:8000/v1
# OPENRND_API_KEY=your-key
# OPENRND_MODEL=your-model-name

# ---- Trust workspace for headless/non-interactive mode ----
OPENRND_TRUST_WORKSPACE=true

# ---- Google Gemini API (optional fallback) ----------------
# GEMINI_API_KEY=your-gemini-api-key

# ---- MCP Server configuration (in ~/.openrnd/settings.json)
# See docs/mcp-configuration.md for details
