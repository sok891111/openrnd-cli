# API keys and secrets
.env
.env~

# openrnd user settings — contains API keys, never commit
# ~/.openrnd/settings.json is the user-level config (outside the repo)
# .openrnd/settings.json inside a project is workspace config — safe to commit
# if it contains no credentials. Add it here if you put secrets in it.
# .openrnd/settings.json

# Legacy gemini-cli settings (kept for compatibility)
**/.gemini/
!/.gemini/
.gemini/*
!.gemini/config.yaml
!.gemini/commands/
!.gemini/skills/
!.gemini/settings.json

# Dependency directory
node_modules
bower_components

# Editors
.idea
*.iml

# OS metadata
.DS_Store
Thumbs.db

# TypeScript build info files
*.tsbuildinfo

# Ignore built ts files
dist

# Docker folder to help skip auth refreshes
.docker

bundle

# Test report files
junit.xml
packages/*/coverage/

# Generated files
packages/cli/src/generated/
packages/core/src/generated/
packages/devtools/src/_client-assets.ts
.integration-tests/
.perf-tests/
packages/vscode-ide-companion/*.vsix
packages/cli/download-ripgrep*/

# GHA credentials
gha-creds-*.json

# Log files
patch_output.log
gemini-debug.log

.genkit
.gemini-clipboard/
.eslintcache
evals/logs/

temp_agents/

# conductor extension and planning directories
conductor/

# Large test fixtures that exceed GitHub's 50MB limit
memory-tests/large-chat-session.json
